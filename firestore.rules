rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidScore(data) {
      return data.keys().hasAll(['uid', 'name', 'score', 'date']) &&
             data.keys().size() == 4 &&
             data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid &&
             data.name is string && data.name.size() <= 64 &&
             data.score is number &&
             data.date is string && data.date.size() <= 64;
    }

    match /leaderboard/{scoreId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(scoreId) && isValidScore(incoming());
      allow update: if false; // Scores are immutable
      allow delete: if false;
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['name', 'hostName', 'hostUid', 'status', 'playerCount']) &&
             data.name is string && data.name.size() <= 64 &&
             data.hostName is string && data.hostName.size() <= 64 &&
             data.hostUid is string && data.hostUid.size() <= 128 &&
             data.status is string && data.status.size() <= 16 &&
             data.playerCount is number;
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(roomId) && isValidRoom(incoming()) && incoming().hostUid == request.auth.uid;
      allow update: if isSignedIn() && isValidId(roomId) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['status']) && existing().hostUid == request.auth.uid) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['playerCount']))
      );
      allow delete: if isSignedIn() && existing().hostUid == request.auth.uid;

      function isValidRoomPlayer(data) {
        return data.keys().hasAll(['uid', 'name']) &&
               data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid &&
               data.name is string && data.name.size() <= 64;
      }

      match /players/{playerId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidId(playerId) && playerId == request.auth.uid && isValidRoomPlayer(incoming());
        allow update: if isSignedIn() && playerId == request.auth.uid &&
          incoming().diff(existing()).affectedKeys().hasOnly(['health', 'score', 'isReady', 'gameOver']);
        allow delete: if isSignedIn() && playerId == request.auth.uid;
      }
    }
  }
}
